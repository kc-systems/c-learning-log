#include <stdio.h>

int grid[100][100];
int N, M;

int is_peak(int r, int c){

    int dc[] = {-1, 1, 0, 0, 1, 1, -1, -1};
    int dr[] = {0, 0, 1, -1, -1, 1, 1, -1};

    for(int i; i < 8; i++){
        int nr = r + dr[i];
        int nc = c + dc[i];

        if(nr >= 0 && nr < N && nc >= 0 && nc < M){    
        if(grid[nr][nc] > grid[r][c])
            return 0;
        }
    }

    return 1;
}

int main(){
 
   scanf("%d %d", &N, &M);

   for(int i = 0; i < N; i++){
    for(int j = 0; j < M; j++ ){

        scanf(" %d", &grid[i][j]);
    }
   }

   for(int i = 0; i < N; i++){
    for(int j = 0; j < M; j++ ){

        if(is_peak(i, j)){
            printf("%d %d\n", i, j);
        }

       
    }
   }

   










  return 0;

}