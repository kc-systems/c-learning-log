// Work on the insert function below // 
void insert(node_t * tree, int val)
{
  if (tree->val == 0)
  {
    
     tree->val = val;
     return;
  }
  else
  {
    if (val < tree->val)
    {
      
      if (tree->left != NULL)
      {
        insert(tree->left, val);
      }
      else
      {
        tree->left = (node_t *) malloc(sizeof(node_t));
        tree -> left = (node_t*) calloc(1, sizeof(node_t));
        tree->left->left = NULL;
        tree->left->right = NULL;
      }
    }
    else
    {
      if (val >= tree->val)
      {

        if (tree->right != NULL)
        {
          insert(tree->right,val);
        }
        else
        {
          tree->right = (node_t *) malloc(sizeof(node_t));
         tree -> right = (node_t*) calloc(1, sizeof(node_t));
          tree->right->val = val;
          tree->right->left = NULL;
          tree->right->right = NULL;
        }
      }
    }
  }
}

/* depth-first search */
void printDFS(node_t * tree)
{
  /* change the code here */
  if (tree == NULL)         return;   /* security measure */
  if (tree ->left != NULL)   printDFS(tree->left);
  if (tree != NULL)         printf("%d ", tree->val);
  if (tree ->right != NULL)  printDFS(tree->right);
}