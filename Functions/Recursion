    #include <stdio.h>
#include <math.h>
// like a loop that needs two conditons set. A terminating casse & Recursive step//
unsigned int factorial(unsigned int x)
{
    if (x == 0)
    {
        /* Terminating case */
        return 1;
    }
   // recursive step//
    return x * factorial(x-1);
}

    
    int main() {
        /* testing code */
        printf("0! = %i\n", factorial(0));
        printf("1! = %i\n", factorial(1));
        printf("3! = %i\n", factorial(3));
        printf("5! = %i\n", factorial(5));
    }
 