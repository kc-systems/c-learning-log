    #include <stdio.h>
  
    /* define the union here */
    union intcharacters
    {
        int a;
        int b;
        int c;
        int d;
        int e;
        int f;
        char byte[21];
    };
    

  
    int main() {
    
        // initializer lists like this are assigned to the first member of the union/struct!
        // There are 6 ints here so...
         union intcharacters data; 
         
         data.a = 1853169737;
         data.b = 1936876900;
         data.c = 1684955508;
         data.d = 1768838432;
         data.e = 561213039;
         data.f= 0; 
      
        /* testing code */
        printf("[");
        // only go to 18 because 1 byte is for the terminating 0 and we don't print the last in the loop
        for(int i = 0; i < 19; ++i)
            printf("%c, ", data.byte[i]);
        printf("%c]\n", data.byte[19]);
    
        printf("%s\n", data.byte);
    }